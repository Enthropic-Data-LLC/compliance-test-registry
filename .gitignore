# ── Local config overrides ────────────────────────────────────────────────────
# conftest.py files with real data-source wiring should not be committed
# unless they contain no credentials or environment-specific paths.
# Uncomment the line below if your conftest.py connects to a real DB:
# conftest.py

# ── Secrets and credentials ───────────────────────────────────────────────────
*.env
.env.*
secrets.yaml
secrets.yml
credentials.json
*.pem
*.key

# ── Generated / compiled assumption hashes ───────────────────────────────────
# CI pipeline populates cryptographic_hash fields; do not commit intermediate
# hash staging files.
*.hash.tmp
assumption_hashes_staging.yaml
